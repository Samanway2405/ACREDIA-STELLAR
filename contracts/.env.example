# ACREDIA contract deployment environment example
# Copy this file to `.env` only when deploying or operating a contract.
# Keep any Stellar secret keys in your local CLI key store or hosting secret store.

# Use `testnet` for development deployments. Use `public` only for audited mainnet releases.
STELLAR_NETWORK=testnet

# Local Stellar CLI identity used by deployment commands, for example:
#   stellar keys generate --network testnet deployer
STELLAR_SOURCE_ACCOUNT=deployer

# Fill this after deployment if scripts need to invoke an existing contract.
STELLAR_CONTRACT_ID=

# Production safety:
# Never commit Stellar secret keys.
# Never paste secret keys into screenshots, logs, browser code, or GitHub issues.
